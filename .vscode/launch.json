{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Controller",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/src/controller/Controller",
            "args": [
                "${workspaceFolder}/config.yaml"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "NS_LOG",
                    "value": "VDA Simulation=info"

                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },
